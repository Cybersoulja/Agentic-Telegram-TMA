{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "telegram-mini-app-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "MINI_APP_URL": "https://telegram-mini-app-frontend.pages.dev",
    "N8N_URL": "http://localhost:5678",
    "QWEN_TTS_URL": "http://localhost:8080",
    "NOVELAI_AGENT_PATH": "<path-to-novelai-lorebook-agent>"
  },
  "kv_namespaces": [
    {
      "binding": "TMA_KV",
      "id": "tma-kv-dev"
    }
  ],
  "d1_databases": [
    {
      "binding": "TMA_DB",
      "database_name": "tma_db",
      "database_id": "tma-db-dev"
    }
  ]
}
