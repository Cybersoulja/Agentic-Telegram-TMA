# Set your Telegram Bot Token obtained from @BotFather
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"

# Override Mini App URL during local development (typically pointing to your local Vite dev server)
MINI_APP_URL="http://localhost:5173"

# Optional: override the local integrations hub endpoints (see wrangler.jsonc for defaults)
# N8N_URL="http://localhost:5678"
# QWEN_TTS_URL="http://localhost:8080"
# NOVELAI_AGENT_PATH="/path/to/your/novelai-lorebook-agent"
# MIRROR_LEECH_URL="http://localhost:8095"
# BLUESKY_PDS_URL="http://localhost:2583"

# Optional: enables the Trill Astro Buzz agent chain (Intent -> Oracle -> Reflection -> Narrative)
# for any non-/start text message. Without it, the bot only responds to /start.
# GEMINI_API_KEY="your_gemini_api_key"
